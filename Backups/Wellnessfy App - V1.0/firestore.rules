rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      // Anyone can read public profiles
      allow read: if request.auth != null;
      // Only the user can update their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Posts collection
    match /posts/{postId} {
      // Anyone authenticated can read posts
      allow read: if request.auth != null;
      // Anyone authenticated can create posts
      allow create: if request.auth != null;
      // Only the author can update/delete their posts
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.author.uid;
    }
    
    // Challenges collection
    match /challenges/{challengeId} {
      // Anyone authenticated can read challenges
      allow read: if request.auth != null;
      // Anyone authenticated can create challenges
      allow create: if request.auth != null;
      // Anyone authenticated can update challenges (for progress tracking)
      // In a production app, you'd want stricter rules
      allow update: if request.auth != null;
      // Only authenticated users can delete challenges
      allow delete: if request.auth != null;
    }
    
    // Activities collection
    match /activities/{activityId} {
      // Anyone authenticated can read activities
      allow read: if request.auth != null;
      // Anyone authenticated can create activities
      allow create: if request.auth != null;
      // Users can update/delete their own activities
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // Circles collection
    match /circles/{circleId} {
      // Anyone authenticated can read circles
      allow read: if request.auth != null;
      // Anyone authenticated can create circles
      allow create: if request.auth != null;
      // Only the creator can delete circles
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.createdBy;
      // Creator or members can update circles (using 'members' field)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy ||
        request.auth.uid in resource.data.members
      );
    }
    
    // Circle Invitations collection
    match /circleInvitations/{invitationId} {
      // Users can read their own invitations
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to
      );
      // Anyone can create invitations
      allow create: if request.auth != null;
      // Only sender or recipient can update/delete
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to
      );
    }
    
    // Friend Requests collection
    match /friendRequests/{requestId} {
      // Users can read their own friend requests
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to
      );
      // Anyone can create friend requests
      allow create: if request.auth != null;
      // Only sender or recipient can update/delete
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to
      );
    }
    
    // Friendships collection (NEW - for Google+ style circles)
    match /friendships/{friendshipId} {
      // Users can read friendships where they are involved
      allow read: if request.auth != null && 
        request.auth.uid in resource.data.users;
      // Anyone authenticated can create friendships
      allow create: if request.auth != null;
      // Only users involved in the friendship can update it
      allow update: if request.auth != null && 
        request.auth.uid in resource.data.users;
      // Only users involved can delete the friendship
      allow delete: if request.auth != null && 
        request.auth.uid in resource.data.users;
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.to;
      // Anyone authenticated can create notifications
      allow create: if request.auth != null;
      // Only the recipient can update/delete their notifications
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.to;
    }
    
    // Goals subcollection (nested under users)
    match /users/{userId}/goals/{goalId} {
      // Users can only read/write their own goals
      allow read, write: if request.auth != null && 
        request.auth.uid == userId;
    }
    
    // Daily Summaries subcollection (nested under users)
    match /users/{userId}/dailySummaries/{summaryId} {
      // Users can only read/write their own daily summaries
      allow read, write: if request.auth != null && 
        request.auth.uid == userId;
    }
  }
}
